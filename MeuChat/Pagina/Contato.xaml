<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MeuChat.Classes"
             x:DataType="local:Pessoas"
             x:Class="MeuChat.Pagina.Contato"
             Title="Contato">
    <VerticalStackLayout Margin="10" HorizontalOptions="Center" Padding="10">
        
        <HorizontalStackLayout HorizontalOptions="Center">
            <Label Text="ID: " FontAttributes="Bold" HorizontalTextAlignment="Center" FontSize="Large" />
            <Entry x:Name="TXTID" FontSize="Large" Text="{Binding Id}" IsEnabled="False"/>
        </HorizontalStackLayout>
        
        <HorizontalStackLayout>
            <Label Text="Nome: " FontAttributes="Bold" HorizontalTextAlignment="Center" FontSize="Large"/>
            <Entry x:Name="TXTNome" HorizontalTextAlignment="Center" FontSize="Large" Text="{Binding Nome}"/>
        </HorizontalStackLayout>

        <HorizontalStackLayout>
            <Label Text="E-Mail: " FontAttributes="Bold" HorizontalTextAlignment="Center" FontSize="Large"/>
            <Entry x:Name="TXTEmail" HorizontalTextAlignment="Center" FontSize="Large" Text="{Binding Email}"/>
        </HorizontalStackLayout>

        <HorizontalStackLayout>
            <Label Text="Tel: " FontAttributes="Bold" HorizontalTextAlignment="Center" FontSize="Large"/>
            <Entry x:Name="TXTTel" HorizontalTextAlignment="Center" FontSize="Large" Text="{Binding Telefone}"/>
        </HorizontalStackLayout>

        <HorizontalStackLayout>
            <Label Text="Obs: " FontAttributes="Bold" HorizontalTextAlignment="Center" FontSize="Large"/>
            <Entry x:Name="TXTObs" HorizontalTextAlignment="Center" FontSize="Large" Text="{Binding Anotacoes}"/>
        </HorizontalStackLayout>

        <Button x:Name="BTNSalvar" Text="Salvar" Clicked="BTNSalvar_Clicked"/>
        <Button x:Name="BTNCancel" Text="Cancelar" TextColor="Red" BackgroundColor="Transparent" Clicked="BTNCancel_Clicked"/>
        
    </VerticalStackLayout>
</ContentPage>